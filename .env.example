# Telegram
BOT_TOKEN=
ADMIN_BOT_TOKEN=
CHANNEL_USERNAME=@seabluushop
ADMIN_GROUP_ID=

# Neon Postgres — тот же коннекшн-стринг, что и в текущей проде.
# Структуру и данные в этой базе трогать не нужно — сервис только читает/пишет
# через существующий код, схему не меняет.
NEON_DATABASE_URL=

# Публичный адрес сервиса (для вебхуков ботов и Secure-cookie).
# Обязательно https:// в проде — от этого зависит, будет ли cookie админки
# помечена Secure (см. app/web_admin.py).
PUBLIC_URL=https://seabluu.kz
PORT=8080

# Веб-админка
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DEFAULT_PASSWORD=
SECRET_KEY=
